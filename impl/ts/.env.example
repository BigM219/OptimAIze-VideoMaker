# OptimAIze-VideoMaker (TS) environment. Copy to .env and fill in.
# .env is gitignored - never commit real secrets.

OPTIMAIZE_ENV=dev
# OPTIMAIZE_WORK_MAX_SANDBOXES=2
# OPTIMAIZE_API_KEY=

# OpenRouter LLM (comma-separated ordered fallback list).
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/owl-alpha,poolside/laguna-m.1:free,nvidia/nemotron-3-ultra-550b-a55b:free,moonshotai/kimi-k2.6:free
