OPTIMAIZE_ENV=dev
# OPTIMAIZE_API_KEY=

# OpenRouter LLM. OPENROUTER_MODEL is a comma-separated ordered fallback list.
# A model entry prefixed "zai:" routes to z.ai instead of OpenRouter (own key
# below), letting you mix providers in one fallback chain. Keep z.ai last for
# lowest priority.
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=moonshotai/kimi-k2.6:free,nvidia/nemotron-3-ultra-550b-a55b:free,poolside/laguna-m.1:free,nvidia/nemotron-3-super-120b-a12b:free,poolside/laguna-xs.2:free,google/gemma-4-31b-it:free,openai/gpt-oss-120b:free,google/gemma-4-26b-a4b-it:free,qwen/qwen3-coder:free,openrouter/owl-alpha,zai:glm-5.1

# z.ai (OpenAI-compatible). Used for any model entry prefixed "zai:".
ZAI_API_KEY=REPLACE_WITH_YOUR_ZAI_KEY
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# z.ai also exposes an Anthropic-format endpoint at
# https://api.z.ai/api/anthropic (e.g. ANTHROPIC_BASE_URL for
# Anthropic-SDK / Claude Code clients). VideoMaker's zai: routing uses
# the OpenAI-compatible /api/paas/v4 endpoint above.
